import os
from openai import OpenAI # import openai
from google.colab import userdata
from google.colab import drive # add drive
drive.mount('/content/drive', force_remount=True) # mount to google drive
api_key = userdata.get('SHARED_CLUB_KEY') # replace with own key
drive_path = "/content/drive/My Drive/" # google drive folder path, can change to different folder

client = OpenAI(api_key = api_key) 
def runAgent(prompt): # runs a call to chatgpt 
  response = client.responses.create(
    model="gpt-4.1-mini",
    input=prompt
  )
  finaloutput = response.output_text
  return finaloutput # returns the response from chatgpt

def getDriveFiles(path): # gets the list of drive files as fileslist
  if os.path.exists(path):
    try:
      files_in_drive = os.listdir(path)
      fileslist = ""

      for file_name in files_in_drive:
        full_path = os.path.join(path, file_name)
        if os.path.isfile(full_path):
            fileslist = fileslist + "\n" + str(file_name)
      return files_in_drive, fileslist

    except Exception as e:
      print(f"Error accessing Google Drive contents: {e}")
      print("Please ensure you have granted necessary permissions and the path exists.")
  else:
    print(f"Directory {drive_path} does not exist. Ensure your drive is mounted correctly and you are checking the right path (e.g., /content/drive/My Drive/).")
  return [], ""
  

files_in_drive, fileslist = getDriveFiles(drive_path)
response = "no"
filetofind = ""
previousguesses = ""
attempts = 0
filefound = "notfound"

while response.lower().strip() != "yes" and response.lower().strip() != "y": # if user indicates that file is found
  attempts +=1 # count attempts
  filetofind += "\n newest info: " + input("What file are you looking for? ") # adds new info for chatgpt 
  filefound = (runAgent(f"""The user is looking for a file in their drive like this: 
                        {filetofind} 
                        Please attempt to find it in this string: 
                        {fileslist} (end list) 
                        Give me the name of the file that you believe to be correct, formatted like this: filename.png 
                        It should only be the file name, no other text. 
                        If you cannot find it or have a problem, respond with the word unsure and nothing else. 
                        Do not ever just repeat the prompt, it must be found in the list of files provided. 
                        You have already guessed the following: {previousguesses} 
                        Feel free to guess one twice if you are sure."""))      # gives list of files and description of file that the user is looking for. chatgpt returns the filename guess or the word "unsure" if a guess cannot be accurately made
  
  previousguesses += "\n " + filefound # logs the past guesses of chatgpt for its future reference as data is not stored between calls
  if filefound != "unsure": # if chatgpt doesn't have a confident guess
    response = input(f"Is \"{filefound}\" the file that you were looking for? Yes or No: ") # ask for confirmation if chatgpt has guessed correctly
    if (response.lower() == "no" or response.lower() == "n") and attempts <= 3: # if incorrect and within 3 attempts try again
      print("I couldn't find it. Try giving me more info.")
  else:
    print("I couldn't find it. Try rephrasing it.") 
  if attempts > 3:
    print("It took too long and I can't find it.") 
    filefound = "notfound"
    break # close loop

if filefound[-3:] == "txt": # summarizes the file if it is a .txt
  for file_name in files_in_drive: # check every file
    full_path = os.path.join(drive_path, file_name) 
    if os.path.isfile(full_path) and file_name == filefound: # if name matches
      with open(full_path, 'r', encoding='utf-8') as f: # open txt file
        filestring = f.read() # reads to a string
      print("Below is a summary of the text file: \n" + runAgent(f"The user wants you to summarize this text file (short). Use bullet points to improve readability. Do not attempt to use bold or italics. the title is {filefound} and the following is its contents: {filestring}")) # prints a summary of the .txt file
elif filefound == "notfound": # failsafe if file was not found
  print("The file could not be found.")
else: # when file is not a text file
  print("Because it is not a text file, it cannot be summarized at this time.")
